{
  "name": "tab-stack",
  "displayName": "Tab Stack",
  "description": "Utility to improve tab management. Enables saving, restoring and quick switching between tab groups and snapshots.",
  "publisher": "ayecue",
  "author": {
    "name": "ayecue",
    "email": "soerenwehmeier@googlemail.com"
  },
  "icon": "icon.png",
  "version": "1.2.7",
  "repository": {
    "type": "git",
    "url": "git@github.com:ayecue/tab-stack.git"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/color-convert": "^2.0.0",
    "@types/glob": "^8.1.0",
    "@types/handlebars": "^4.0.40",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.12.12",
    "@types/object-inspect": "^1.13.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^5.27.1",
    "@typescript-eslint/parser": "^5.27.1",
    "@vitest/coverage-v8": "^2.1.4",
    "@vscode/test-electron": "^2.0.3",
    "@vscode/test-web": "^0.0.56",
    "esbuild": "0.21.0",
    "esbuild-plugin-globals": "0.2.0",
    "esbuild-plugin-polyfill-node": "0.3.0",
    "eslint": "^8.17.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-security": "^1.5.0",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "fishery": "^2.2.0",
    "glob": "^11.0.0",
    "happy-dom": "^14.10.1",
    "jest-mock-vscode": "^4.8.2",
    "mocha": "^10.7.3",
    "ovsx": "^0.10.1",
    "source-map-support": "^0.5.12",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.4",
    "vsce": "^2.15.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:ts && npm run compile:node && npm run compile:browser && npm run compile:webview",
    "compile:ts": "tsc -p ./",
    "compile:node": "node build-node.cjs",
    "compile:webview": "node build-webview.cjs",
    "compile:browser": "node build-browser.cjs",
    "compile:extension": "vsce package --out extension.vsix --allow-star-activation",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{ts,tsx}\"",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "pretest:integration": "npm run compile",
    "test:integration": "node ./tests/integration/runTest.cjs",
    "test:browser": "npm run compile:ts && npm run compile:browser && vscode-test-web --extensionDevelopmentPath=. ."
  },
  "homepage": "https://github.com/ayecue/tab-stack",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "main": "extension.js",
  "browser": "extension.browser.js",
  "qna": "false",
  "bugs": {
    "url": "https://github.com/ayecue/tab-stack/issues"
  },
  "keywords": [
    "tabs",
    "groups",
    "snapshots",
    "tab management",
    "tab groups",
    "tab snapshots",
    "workspace",
    "productivity"
  ],
  "activationEvents": [
    "*"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tabStack",
          "title": "Tab Stack",
          "icon": "icons/activitybar.svg"
        }
      ]
    },
    "views": {
      "tabStack": [
        {
          "type": "webview",
          "id": "tabStackView",
          "name": "Tab Stack",
          "when": "true",
          "icon": "icons/activitybar.svg"
        }
      ]
    },
    "menus": {
      "editor/title/run": [],
      "editor/context": [],
      "explorer/context": [],
      "commandPalette": []
    },
    "submenus": [],
    "commands": [
      {
        "command": "tabStack.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "tabStack.quickSwitch",
        "title": "Quick Switch Between Last Two States",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.clearSelection",
        "title": "Clear Current Selection",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.switchGroup",
        "title": "Apply Saved Group",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.createGroup",
        "title": "Save Current Tabs as Group",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.deleteGroup",
        "title": "Delete Saved Group",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.snapshot",
        "title": "Capture Tabs Snapshot",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.restoreSnapshot",
        "title": "Restore Tabs Snapshot",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.deleteSnapshot",
        "title": "Delete Tabs Snapshot",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.createAddon",
        "title": "Save Current Tabs as Add-on",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.applyAddon",
        "title": "Apply Add-on (Add Tabs)",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.deleteAddon",
        "title": "Delete Add-on",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.assignQuickSlot",
        "title": "Assign Current Group to Quick Slot",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.clearQuickSlot",
        "title": "Clear Quick Slot Assignment",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.clearAllTabs",
        "title": "Close All Tabs",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.exportGroup",
        "title": "Export Group to File",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.importGroup",
        "title": "Import Group from File",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.quickSlot1",
        "title": "Apply Quick Slot 1",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.quickSlot2",
        "title": "Apply Quick Slot 2",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.quickSlot3",
        "title": "Apply Quick Slot 3",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.quickSlot4",
        "title": "Apply Quick Slot 4",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.quickSlot5",
        "title": "Apply Quick Slot 5",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.quickSlot6",
        "title": "Apply Quick Slot 6",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.quickSlot7",
        "title": "Apply Quick Slot 7",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.quickSlot8",
        "title": "Apply Quick Slot 8",
        "category": "Tab Stack"
      },
      {
        "command": "tabStack.quickSlot9",
        "title": "Apply Quick Slot 9",
        "category": "Tab Stack"
      }
    ],
    "keybindings": [
      {
        "command": "tabStack.quickSlot1",
        "key": "ctrl+alt+shift+1",
        "mac": "cmd+alt+shift+1"
      },
      {
        "command": "tabStack.quickSlot2",
        "key": "ctrl+alt+shift+2",
        "mac": "cmd+alt+shift+2"
      },
      {
        "command": "tabStack.quickSlot3",
        "key": "ctrl+alt+shift+3",
        "mac": "cmd+alt+shift+3"
      },
      {
        "command": "tabStack.quickSlot4",
        "key": "ctrl+alt+shift+4",
        "mac": "cmd+alt+shift+4"
      },
      {
        "command": "tabStack.quickSlot5",
        "key": "ctrl+alt+shift+5",
        "mac": "cmd+alt+shift+5"
      },
      {
        "command": "tabStack.quickSlot6",
        "key": "ctrl+alt+shift+6",
        "mac": "cmd+alt+shift+6"
      },
      {
        "command": "tabStack.quickSlot7",
        "key": "ctrl+alt+shift+7",
        "mac": "cmd+alt+shift+7"
      },
      {
        "command": "tabStack.quickSlot8",
        "key": "ctrl+alt+shift+8",
        "mac": "cmd+alt+shift+8"
      },
      {
        "command": "tabStack.quickSlot9",
        "key": "ctrl+alt+shift+9",
        "mac": "cmd+alt+shift+9"
      },
      {
        "command": "tabStack.quickSwitch",
        "key": "ctrl+alt+shift+0",
        "mac": "cmd+alt+shift+0"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Tab Stack",
      "properties": {
        "tabStack.masterWorkspaceFolder": {
          "type": "string",
          "default": null,
          "description": "Path to the workspace folder to use for storing tab state and tracking git branches. If not set, the first workspace folder will be used."
        },
        "tabStack.gitIntegration.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable automatic group management based on git branch changes."
        },
        "tabStack.gitIntegration.mode": {
          "type": "string",
          "enum": [
            "auto-switch",
            "auto-create",
            "full-auto"
          ],
          "enumDescriptions": [
            "Automatically switch to existing groups when branch changes",
            "Automatically create groups for new branches and switch to them",
            "Fully automatic: create groups for new branches and auto-switch between them"
          ],
          "default": "full-auto",
          "description": "Git integration mode: how Tab Stack manages groups based on git branches."
        },
        "tabStack.gitIntegration.groupPrefix": {
          "type": "string",
          "default": "git:",
          "description": "Prefix for automatically created git-based groups (e.g., 'git:main', 'git:feature/login')."
        },
        "tabStack.history.maxEntries": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum number of snapshots to retain in history. Older entries are pruned automatically."
        },
        "tabStack.storage.type": {
          "type": "string",
          "enum": [
            "file",
            "workspace-state"
          ],
          "enumDescriptions": [
            "Store tab state in .vscode/tmstate.json file (visible and git-trackable)",
            "Store tab state in VS Code's workspace state (hidden, not in git)"
          ],
          "default": "file",
          "description": "Storage method for tab state persistence."
        },
        "tabStack.appearance.tabKindColors": {
          "type": "array",
          "default": [
            { "kind": "tabInputText", "color": "#2472c8" },
            { "kind": "tabInputTextDiff", "color": "#f44747" },
            { "kind": "tabInputCustom", "color": "#c586c0" },
            { "kind": "tabInputWebview", "color": "#2aa198" },
            { "kind": "tabInputNotebook", "color": "#16825d" },
            { "kind": "tabInputNotebookDiff", "color": "#c19c00" },
            { "kind": "tabInputTerminal", "color": "#3b8eea" },
            { "kind": "unknown", "color": "#ff6161" }
          ],
          "description": "Color rules for tab kind labels and icons. Each rule matches by tab kind and optionally by a label regex pattern. The first matching rule wins.",
          "items": {
            "type": "object",
            "required": ["kind", "color"],
            "properties": {
              "kind": {
                "type": "string",
                "description": "Tab kind identifier (e.g. 'tabInputText', 'tabInputWebview', 'unknown')."
              },
              "color": {
                "type": "string",
                "description": "CSS color value (e.g. '#ff6161', 'rgb(255, 97, 97)')."
              },
              "pattern": {
                "type": "string",
                "description": "Optional regex pattern matched against the tab label. When omitted, the rule matches all tabs of the specified kind."
              }
            }
          }
        },
        "tabStack.tabRecoveryMappings": {
          "type": "object",
          "default": {
            "^Settings$": "workbench.action.openSettings",
            "^Keyboard Shortcuts$": "workbench.action.openGlobalKeybindings",
            "^Extensions$": "workbench.view.extensions",
            "^Output$": "workbench.action.output.toggleOutput",
            "^Problems$": "workbench.actions.view.problems",
            "^Debug Console$": "workbench.debug.action.toggleRepl",
            "^Terminal$": "workbench.action.terminal.toggleTerminal",
            "^Search$": "workbench.action.findInFiles",
            "^Source Control$": "workbench.view.scm",
            "^Explorer$": "workbench.view.explorer",
            "^Run and Debug$": "workbench.view.debug",
            "^Testing$": "workbench.view.testing",
            "^Welcome$": "workbench.action.openWalkthrough",
            "^Release Notes$": "update.showCurrentReleaseNotes",
            "^Ports$": "workbench.panel.ports.focus",
            "^Comments$": "workbench.panel.comments.focus",
            "^Interactive Playground$": "workbench.action.showInteractivePlayground"
          },
          "description": "Mapping of identifiers to recovery commands for unknown tab types. Keys serve as identifiers (or as label regex patterns for backward compatibility). Values are either a command ID string (key is the label pattern) or an object with 'command', optional 'match' (regex criteria including 'label'), optional 'args', and optional 'nextTickDelay'.",
          "patternProperties": {
            ".*": {
              "oneOf": [
                {
                  "type": "string",
                  "description": "VS Code command ID to execute. The key is used as a regex pattern matched against the tab label."
                },
                {
                  "type": "object",
                  "properties": {
                    "command": {
                      "type": "string",
                      "description": "VS Code command ID to execute."
                    },
                    "args": {
                      "type": "array",
                      "description": "Arguments to pass to the command. String values support ${property} interpolation from the tab info (e.g. ${uri}, ${viewType}, ${label}, ${viewColumn}).",
                      "items": {}
                    },
                    "nextTickDelay": {
                      "type": "number",
                      "description": "Milliseconds to wait after command execution before checking for the tab. 0 or omitted for immediate (setImmediate).",
                      "default": 0
                    },
                    "match": {
                      "type": "object",
                      "description": "Regex criteria matched against tab properties. All specified fields must match. If 'label' is omitted, the mapping key is used as the label pattern.",
                      "properties": {
                        "label": {
                          "type": "string",
                          "description": "Regex pattern to match against the tab label. Overrides the mapping key as the label matcher."
                        },
                        "kind": {
                          "type": "string",
                          "description": "Regex pattern to match against tab kind (e.g. 'tabInputWebview', 'unknown')."
                        },
                        "uri": {
                          "type": "string",
                          "description": "Regex pattern to match against the tab URI."
                        },
                        "viewType": {
                          "type": "string",
                          "description": "Regex pattern to match against the tab viewType."
                        }
                      }
                    }
                  },
                  "required": [
                    "command"
                  ]
                }
              ]
            }
          }
        }
      }
    }
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0",
    "@xstate/store": "^3.11.2",
    "debounce": "^2.2.0",
    "deep-object-diff": "^1.1.9",
    "filter-obj": "^6.1.0",
    "handlebars": "^4.7.9",
    "nanoid": "^5.1.6",
    "non-blocking-schedule": "^0.2.0",
    "object-inspect": "^1.13.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vscode-icons-js": "^11.6.1",
    "xstate": "^5.30.0"
  },
  "browserslist": "> 0.25%, not dead"
}
